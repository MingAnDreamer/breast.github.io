# 硅基流动 API 配置
# 请复制此文件为 .env 并填入你的API Key

# 硅基流动 API Key
# 获取地址: https://cloud.siliconflow.cn/
VITE_SILICONFLOW_API_KEY=your_api_key_here

# 使用的模型名称（可选，默认为 deepseek-ai/DeepSeek-V2.5）
# 可选模型:
# - deepseek-ai/DeepSeek-V2.5
# - deepseek-ai/DeepSeek-V3
# - Qwen/Qwen2.5-72B-Instruct
# - Qwen/Qwen2.5-32B-Instruct
# - THUDM/glm-4-9b-chat
VITE_SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V2.5
